# ─────────────────────────────────────────────────────────────
#  mundial-value-bot — variables de entorno
#  Copiá este archivo a ".env" y completá tus claves.
# ─────────────────────────────────────────────────────────────

# The Odds API — https://the-odds-api.com  (500 créditos/mes gratis)
# Alta instantánea por email. 1 crédito = 1 mercado x 1 región por llamada.
ODDS_API_KEY=

# API-Football — https://dashboard.api-football.com  (100 req/día gratis)
# OJO: el plan gratis NO da acceso a la temporada 2026.
API_FOOTBALL_KEY=

# football-data.org — https://www.football-data.org/client/register  (gratis, 10 req/min)
# Trae los fixtures del Mundial 2026 + árbitro en el tier gratis. Fuente preferida.
FOOTBALL_DATA_KEY=

# Anthropic (Claude) — para la capa de noticias (lee titulares y extrae señales).
ANTHROPIC_API_KEY=
# News API — https://newsapi.org o https://gnews.io (tier gratis). Para la capa de noticias.
NEWS_API_KEY=

# Telegram — creá un bot con @BotFather y pegá el token.
# TELEGRAM_CHAT_ID: tu id de usuario o el id del canal donde recibís los picks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────
#  Gestión de banca (bankroll)
# ─────────────────────────────────────────────────────────────
BANKROLL_USD=100            # banca inicial
KELLY_FRACTION=0.25         # 1/4 Kelly (recomendado para datos ruidosos)
MAX_STAKE_PCT=0.03          # tope por apuesta: 3% de la banca
MAX_TOTAL_EXPOSURE_PCT=0.25 # tope de exposición simultánea: 25%
MIN_EDGE=0.03               # edge mínimo para marcar un pick (+3% EV)

# ─────────────────────────────────────────────────────────────
#  Operación
# ─────────────────────────────────────────────────────────────
ODDS_REGION=eu              # us | uk | eu | au
TIMEZONE=America/Argentina/Buenos_Aires
DAILY_PICKS_HOUR=10         # hora local del envío diario de picks
